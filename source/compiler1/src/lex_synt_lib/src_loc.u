import "src_loc.iu"

namespace U1
{

fn SrcLoc::constructor( u32 file_index, u32 line, u32 column )
	(
		packed_file_index_macro_expansion_index_=
			( file_index << c_num_macro_expansion_index_bits ) | c_max_macro_expanison_index,
		packed_line_column_= ( line << c_num_column_bits ) | ( column & c_max_column )
	)
{
	halt if( file_index > c_max_file_index );
	halt if( line > c_max_line );
	halt if( column > c_max_column );
}

fn SrcLoc::GetFileIndex(this) : u32
{
	return packed_file_index_macro_expansion_index_ >> c_num_macro_expansion_index_bits;
}

fn SrcLoc::GetMacroExpansionIndex(this) : u32
{
	return packed_file_index_macro_expansion_index_ & c_max_macro_expanison_index;
}

fn SrcLoc::GetLine(this) : u32
{
	return packed_line_column_ >> c_num_column_bits;
}

fn SrcLoc::GetColumn(this) : u32
{
	return packed_line_column_ & c_max_column;
}

fn SrcLoc::SetLine( mut this, u32 line )
{
	halt if( line > c_max_line );
	packed_line_column_ &= c_max_column;
	packed_line_column_ |= line << c_num_column_bits;
}

fn SrcLoc::SetFileIndex( mut this, u32 file_index )
{
	halt if( file_index > c_max_file_index );
	packed_file_index_macro_expansion_index_ &= c_max_macro_expanison_index;
	packed_file_index_macro_expansion_index_ |= file_index << c_num_macro_expansion_index_bits;
}

fn SrcLoc::SetMacroExpansionIndex( mut this, u32 macro_expansion_index )
{
	halt if( macro_expansion_index > c_max_macro_expanison_index );
	packed_file_index_macro_expansion_index_ &= ~c_max_macro_expanison_index;
	packed_file_index_macro_expansion_index_ |= macro_expansion_index;
}

op SrcLoc::<=>( SrcLoc& l, SrcLoc& r ) : i32
{
	if( l.packed_file_index_macro_expansion_index_ != r.packed_file_index_macro_expansion_index_ )
	{
		return l.packed_file_index_macro_expansion_index_ <=> r.packed_file_index_macro_expansion_index_;
	}
	return l.packed_line_column_ <=> r.packed_line_column_;
}

} // namespace U1

		static_assert( B_CONSTANT == 78.2 );
		static_assert( same_type</ B_ALIAS, BTypedef /> );
	}

	// Call functions from "a.h" and "b.h" which use names from "common.h".
	{
		var CommonTypedef a= 1.0;
		var struct_::CommonStruct mut b{ .x= 2, .y= 3 };
		var enum_::CommonEnum c= CommonC;
		unsafe( AFuncUsingCommonDefinitions( a, $<( b ), c ) );
		unsafe( BFuncUsingCommonDefinitions( a, $<( b ), c ) );
	}

	return 0;
}

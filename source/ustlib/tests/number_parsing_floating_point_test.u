fn TestF32NumberParsing( ust::string_view8 num_str )
{
	TestNumberParsing</f32/>( num_str );
}

fn TestF64NumberParsing( ust::string_view8 num_str )
{
	TestNumberParsing</f64/>( num_str );
}

template</type T/>
fn TestNumberParsing( ust::string_view8 num_str )
{
	var ust::optional</T/> num_parsed_opt= ust::parse_number_exact</T/>( num_str );
	if( num_parsed_opt.empty() )
	{
		ust::stderr_print( ust::concat( "Failed to parse ", num_str, "!\n" ) );
		halt;
	}

	var T num_parsed= num_parsed_opt.try_deref();
	var T external_parser_result= ParseNumberExternal</T/>( num_str );

	// ust::stdout_print( ust::concat( "Parsed ", num_str, " into ", ust::to_string8( num_parsed ), "\n" ) );

	if( ust::is_nan( num_parsed ) && ust::is_nan( external_parser_result ) )
	{
		// Fine - both results are NAN.
	}
	else if( external_parser_result != num_parsed )
	{
		ust::stderr_print(
			ust::concat(
				"Parsing result for \"",
				num_str,
				"\" is wrong! It should be ",
				ust::to_string8( external_parser_result ),
				" but it's ",
				ust::to_string8( num_parsed ),
				".\n" ) );

		halt;
	}
}

template</ type Func />
fn GeneratePositivePowersOfTenNumberStrings( size_type num_powers_of_ten, Func& func )
{
	var ust::string8 mut s= "1";

	for( auto mut i= 0s; i < num_powers_of_ten; ++i )
	{
		func( s );
		s.push_back( '0' );
	}
}

template</ type Func />
fn GenerateNegativePowersOfTenNumberStrings( size_type num_powers_of_ten, Func& func )
{
	var ust::string8 mut s= "0.1";

	for( auto mut i= 0s; i < num_powers_of_ten; ++i )
	{
		func( s );

		s.back()= '0';
		s.push_back( '1' );
	}
}

template</ type Func />
fn GeneratePositivePowersOfTwoNumberStrings( size_type num_powers_of_ten, Func& func )
{
	var ust::vector</u8/> mut num;
	num.push_back( 1u8 );

	var ust::string8 mut s;

	for( auto mut i= 0s; i < num_powers_of_ten; ++i )
	{
		s.clear();

		foreach( digit : num.range().iter_reverse() )
		{
			s.push_back( char8( u32( '0' ) + u32( digit ) ) );
		}

		func( s );

		var u32 mut carry= 0u;
		foreach( &mut digit : num )
		{
			var u32 digit_scaled= u32( digit ) * 2u + carry;
			digit= u8( digit_scaled % 10u );
			carry= digit_scaled / 10u;
		}

		if( carry > 0u )
		{
			num.push_back( u8( carry ) );
		}
	}
}

template</ type Func />
fn GenerateNegativePowersOfTwoNumberStrings( size_type num_powers_of_ten, Func& func )
{
	var ust::vector</u8/> mut num;
	num.push_back( 5u8 );

	var ust::string8 mut s;

	for( auto mut i= 0s; i < num_powers_of_ten; ++i )
	{
		s.clear();

		s+= "0.";

		for( auto mut j= 0s; j + num.size() < i + 1s; ++j )
		{
			s.push_back( '0' );
		}

		foreach( digit : num.range().iter_reverse() )
		{
			s.push_back( char8( u32( '0' ) + u32( digit ) ) );
		}

		func( s );

		var u32 mut carry= 0u;
		foreach( &mut digit : num )
		{
			var u32 digit_scaled= u32( digit ) * 5u + carry;
			digit= u8( digit_scaled % 10u );
			carry= digit_scaled / 10u;
		}

		if( carry > 0u )
		{
			num.push_back( u8( carry ) );
		}
	}
}

class RandGenerator
{
public:
	fn Next( mut this ) : u32
	{
		state_= ( 22695477u * state_ + 1u ) & 0x7FFFFFFFu;
		return state_ >> 16u;
	}

private:
	u32 state_= 0u;
}

template</type T/>
fn ParseNumberExternal( ust::string_view8 s ) : T
{
	static_if( same_type</ T, f32 /> )
	{
		return ParseF32External( s );
	}
	else static_if( same_type</ T, f64 /> )
	{
		return ParseF64External( s );
	}
	else
	{
		static_assert( false, "Unsupported type!" );
	}
}

fn ParseF32External( ust::string_view8 s ) : f32
{
	// Use a number parsing function from the C standard library.
	// We need it to rule out possible errors in our own number parsing functions.
	scoped_array char8 s_nt[ s.size() + 1s ]( s.iter().chain( ust::string_view8( "\0" ).iter() ) );
	return unsafe( strtof( s_nt.data(), ust::nullptr</ $(char8) />() ) );
}

fn ParseF64External( ust::string_view8 s ) : f64
{
	// Use a number parsing function from the C standard library.
	// We need it to rule out possible errors in our own number parsing functions.
	scoped_array char8 s_nt[ s.size() + 1s ]( s.iter().chain( ust::string_view8( "\0" ).iter() ) );
	return unsafe( strtod( s_nt.data(), ust::nullptr</ $(char8) />() ) );
}

// C standard library functions.
fn nomangle strtof( $(char8) ptr, $($(char8)) end_ptr ) unsafe call_conv( "C" ) : f32;
fn nomangle strtod( $(char8) ptr, $($(char8)) end_ptr ) unsafe call_conv( "C" ) : f64;

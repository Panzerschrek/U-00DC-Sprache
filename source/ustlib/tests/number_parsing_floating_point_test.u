//##success_test
import "../imports/math.iu"
import "../imports/number_parsing.iu"
import "../imports/scoped_array.iu"
import "../imports/stdout.iu"
import "../imports/string.iu"
import "../imports/string_conversions.iu"
import "../imports/vector.iu"

fn nomangle main() call_conv( "C" ) : i32
{
	TestF32Parsing();
	TestF32PowersOfTenParsing();
	TestF32PowersOfTwoParsing();
	TestRandomBitPatternF32Parsing();
	TestRandomNumberStringF32Parsing();

	// Running parsing tests for all f32 numbers isn't fast.
	// It may take 10 to 30 minutes (singlethreaded).
	// So, disable it by-default.
	// Enable it if you want to make changes in code performing "f32" parsing to make sure it's always correct.
	if( false )
	{
		TestAllF32ValuesParsing();
	}

	TestF64Parsing();

	return 0;
}


fn TestF32PowersOfTenParsing()
{
	GeneratePositivePowersOfTenNumberStrings( 44s, TestF32NumberParsing );
	GenerateNegativePowersOfTenNumberStrings( 60s, TestF32NumberParsing );
}

fn TestF32PowersOfTwoParsing()
{
	GeneratePositivePowersOfTwoNumberStrings( 140s, TestF32NumberParsing );
	GenerateNegativePowersOfTwoNumberStrings( 160s, TestF32NumberParsing );
}

fn TestRandomBitPatternF32Parsing()
{
	var RandGenerator mut rand;

	// It's far way less than the total number of "f32" numbers, but is still pretty high.
	var u32 num_tested_random_numbers= 1u << 22u;

	for( auto mut i= 0u; i < num_tested_random_numbers; ++i )
	{
		var u32 rand_bit_pattern= rand.Next() | ( rand.Next() << 16 );

		var f32 num( byte32( rand_bit_pattern ) );

		var ust::string8 num_str= ust::to_string8( num );

		var ust::optional</f32/> num_parsed_opt= ust::parse_number_exact</f32/>( num_str.range() );
		if( num_parsed_opt.empty() )
		{
			ust::stderr_print( ust::concat( "Failed to parse ", num_str, "!\n" ) );
			halt;
		}

		var f32 num_parsed= num_parsed_opt.try_deref();

		if( ust::is_nan( num_parsed ) && ust::is_nan( num ) )
		{
			// Fine - both results are NAN.
		}
		else if( num != num_parsed )
		{
			ust::stderr_print(
				ust::concat(
					"Parsing result for \"",
					num_str,
					"\" is wrong! It is ",
					ust::to_string8( num_parsed ),
					".\n" ) );
			halt;
		}
	}
}

fn TestRandomNumberStringF32Parsing()
{
	var RandGenerator mut rand;

	var ust::string8 mut s;

	var u32 constexpr num_radnom_nums= 1u << 21u;

	for( auto mut i= 0u; i < num_radnom_nums; ++i )
	{
		// Generate a random string with some integer and fractional digits and decimal exponent.

		// Have no more than 10 integer and fractional digits, since it's enough for most practical cases.
		var u32 num_integer_digits= 1u + rand.Next() % 9u;
		var u32 num_fractional_digits= 1u + rand.Next() % 9u;
		var i32 decimal_exponent= i32( rand.Next() % 80u ) - 40;

		s.clear();

		for( auto mut d= 0u; d < num_integer_digits; ++d )
		{
			s.push_back( char8( u32( '0' ) + rand.Next() % 10u ) );
		}

		s.push_back( '.' );

		for( auto mut d= 0u; d < num_fractional_digits; ++d )
		{
			s.push_back( char8( u32( '0' ) + rand.Next() % 10u ) );
		}

		s.push_back( 'e' );
		if( decimal_exponent < 0 )
		{
			s.push_back( '-' );
		}

		var u32 abs_decimal_exponent( ust::abs( decimal_exponent ) );

		s.push_back( char8( u32( '0' ) + abs_decimal_exponent / 10u ) );
		s.push_back( char8( u32( '0' ) + abs_decimal_exponent % 10u ) );

		TestF32NumberParsing( s );
	}
}

fn TestAllF32ValuesParsing()
{
	// Run parsing tests for all possible bit patters of f32 type.

	var u64 total_numbers= 1u64 << 32;

	for( auto mut i= 0u64; i < total_numbers; ++i )
	{
		var f32 num( byte32( u32(i) ) );

		var ust::string8 num_str= ust::to_string8( num );

		var ust::optional</f32/> num_parsed_opt= ust::parse_number</f32/>( num_str.range() );
		if( num_parsed_opt.empty() )
		{
			ust::stderr_print( ust::concat( "Failed to parse ", num_str, "!\n" ) );
			halt;
		}

		var f32 num_parsed= num_parsed_opt.try_deref();

		if( ust::is_nan( num_parsed ) && ust::is_nan( num ) )
		{
			// Fine - both results are NAN.
		}
		else if( num != num_parsed )
		{
			ust::stderr_print(
				ust::concat(
					"Parsing result for \"",
					num_str,
					"\" is wrong! It is ",
					ust::to_string8( num_parsed ),
					".\n" ) );
			halt;
		}

		var u64 progress_printing_step= 4u64 * 1024u64 * 1024u64;
		if( i % progress_printing_step == 0u64 )
		{
			ust::stdout_print( ust::concat( "All f32 values parsing progress: ", ust::to_string8( i / progress_printing_step ), "\n" ) );
		}
	}
}


//##success_test
import "../imports/math.iu"
import "../imports/scoped_array.iu"
import "../imports/string_conversions.iu"

fn nomangle main() call_conv( "C" ) : i32
{
	TestF32Conversions();
	TestRepresentableIntegerF32Conversions();
	TestSomeFractionalF32Conversions();
	TestRandomF32Conversions();
	TestF32ConversionsToWideStringTypes();

	// Running conversion tests for all f32 numbers isn't fast.
	// It may take 10 to 30 minutes (singlethreaded).
	// So, disable it by-default.
	// Enable it if you want to make changes in code performing "f32" stringification to make sure it's always correct.
	if( false )
	{
		TestAllF32Conversions();
	}

	TestF64Conversions();
	TestF64ConversionsForPowersOfTwoAndNearbyNumbers();
	TestF64ConversionsForPowersOfTenAndNearbyNumbers();
	TestRandomF64Conversions();
	TestF64ConversionsToWideStringTypes();

	// If you have some spare time (way longer than the age of the Universe), you can run tests for all f64 numbers too.
	if( false )
	{
		TestAllF64Conversions();
	}

	return 0;
}

fn TestF32Conversions()
{
	// Test exact string output for each given number.
	// Doing so we ensure that the result is pretty enough.
	// But if the implementation changes, we need to correct these test-cases.
	var [ tup[ f32, ust::string_view8 ], 58 ] special_numbers
	[
		[ f32( byte32( 0xffc00001u ) ), "-nan" ], // Negative signaling NaN.
		[ f32( byte32( 0xff800001u ) ), "-nan" ], // Negative quiet NaN.
		[ -( 0.0f / 0.0f ), "-nan" ], // Negative NaN.
		[ -1.0f / 0.0f, "-inf" ], // Negative infinity.
		[ -3.402823466385288598117042e38f, "-34028235e31" ],
		[ -678953536.0f, "-67895356e1" ],
		[ -100500.0f, "-100500" ],
		[ -2.25f, "-2.25" ],
		[ -1.0f, "-1" ],
		[ -0.125f, "-0.125" ],
		[ -0.0f, "-0" ],
		[ 0.0f, "0" ],
		[ f32( byte32( 0x00000001u ) ), "17e-46" ], // Smallest subnormal number.
		[ f32( byte32( 0x004244b9u ) ), "6085796e-45" ], // A subnormal number above the smallest and below the largest.
		[ f32( byte32( 0x007fffffu ) ), "11754942e-45" ], // Largest subnormal number.
		[ f32( byte32( 0x00800000u ) ), "11754944e-45" ], // Smallest normal number.
		[ f32( byte32( 0x00800001u ) ), "11754945e-45" ], // Smallest normal number + 1.
		[ f32( byte32( 0x027e35a1u ) ), "18676364e-44" ], // 1.8676364e-37
		[ 0.0009765625f, "9765625e-10" ],
		[ 0.001953125f, "1953125e-9" ],
		[ 0.0234375f, "234375e-7" ],
		[ 0.046875f, "46875e-6" ],
		[ 0.0625f, "625e-4" ],
		[ 0.125f, "0.125" ],
		[ 0.1250000298023223876953125f, "0.12500003" ],
		[ 0.300000011920928955078125f, "0.30000002" ], // Value closest to 0.3.
		[ 0.875f, "0.875" ],
		[ 0.999999940395355224609375f, "0.99999996" ],
		[ 1.0f, "1" ],
		[ 1.00000011920928955078125f, "1.0000001" ],
		[ 1.0000005f, "1.0000005" ],
		[ 1.2000000476837158203125f, "1.2000001" ], // Value closest to 1.2.
		[ 2.0f, "2" ],
		[ 2.0000002384185791015625f, "2.0000003" ],
		[ 2.5f, "2.5" ],
		[ 785.25f, "785.25" ],
		[ 255.9999847412109375f, "255.99999" ],
		[ 256.0f, "256" ],
		[ 256.000030517578125f, "256.00004" ],
		[ 1000.0f, "1000" ],
		[ 20000.0f, "20000" ],
		[ 21000.0f, "21000" ],
		[ 3000000.0f, "3000000" ],
		[ 4520000.0f, "4520000" ],
		[ 5732546.0f, "5732546" ],
		[ 5732546.5f, "5732546.7" ],
		[ 354897568.0f, "35489758e1" ],
		[ 6753467904.0f, "6753468e3" ],
		[ 67554346597875712.0f, "67554348e9" ],
		[ 36893485948395847680.0f, "36893486e12" ],
		[ 57645866265625481818199293952.0f, "57645868e21" ],
		[ 6.540669468281527821706070e35f, "65406696e28" ],
		[ 3.402823263561192561600338e38f, "34028233e31" ], // Value previous to max finite f32.
		[ 3.402823466385288598117042e38f, "34028235e31" ], // Max finite f32.
		[ 1.0f / 0.0f, "inf" ], // Infinity.
		[ 0.0f / 0.0f, "nan" ], // NaN.
		[ f32( byte32( 0x7f800001u ) ), "nan" ], // Quiet NaN.
		[ f32( byte32( 0x7fc00001u ) ), "nan" ], // Signaling NaN.
	];

	// Test conversion itself.
	foreach( &pair : special_numbers )
	{
		TestF32Conversion( pair[0] );
	}

	// Test exact string output.
	foreach( &pair : special_numbers )
	{
		var ust::string8 s= ust::to_string8( pair[0] );
		halt if( s != pair[1] );
	}
}

fn TestRepresentableIntegerF32Conversions()
{
	// Test several million or so integers converted to "f32",
	// but only as long as we have enough precision to represent them exactly.

	auto mut i= 0u;
	loop
	{
		var f32 num(i);
		if( u32(num) != i )
		{
			break;
		}
		++i;

		TestF32Conversion( num );
	}
}

fn TestSomeFractionalF32Conversions()
{
	// Test all values having the same binary order.

	var f32 begin= 0.5f;
	var f32 end= 1.0f;

	for( var u32 mut i( byte32( begin ) ); i < u32( byte32( end ) ); ++i )
	{
		TestF32Conversion( f32( byte32(i) ) );
	}
}

fn TestRandomF32Conversions()
{
	var RandGenerator mut rand;

	// It's way less than the total number of "f32" numbers, but is still pretty high.
	var u32 num_tested_random_numbers= 1u << 22u;

	for( auto mut i= 0u; i < num_tested_random_numbers; ++i )
	{
		var u32 rand_bit_pattern= rand.Next() | ( rand.Next() << 16u );

		TestF32Conversion( f32( byte32( rand_bit_pattern ) ) );
	}
}

fn TestF32ConversionsToWideStringTypes()
{
	// Test only some selected values.
	// We don't require testing them all, since underlying implemetation should really not depend on string type.

	halt if( ust::to_string16( 0.0f ) != "0"u16 );
	halt if( ust::to_string16( -0.0f ) != "-0"u16 );
	halt if( ust::to_string16( 0.0009765625f ) != "9765625e-10"u16 );
	halt if( ust::to_string16( 675.125f ) != "675.125"u16 );
	halt if( ust::to_string16( -266732.0f ) != "-266732"u16 );
	halt if( ust::to_string16( 36893485948395847680.0f ) != "36893486e12"u16 );
	halt if( ust::to_string16( ust::plus_inf </f32/>() ) !=  "inf"u16 );
	halt if( ust::to_string16( ust::minus_inf</f32/>() ) != "-inf"u16 );
	halt if( ust::to_string16( 0.0f / 0.0f ) != "nan"u16 );

	halt if( ust::to_string32( 0.0f ) != "0"u32 );
	halt if( ust::to_string32( -0.0f ) != "-0"u32 );
	halt if( ust::to_string32( 0.0009765625f ) != "9765625e-10"u32 );
	halt if( ust::to_string32( 675.125f ) != "675.125"u32 );
	halt if( ust::to_string32( -266732.0f ) != "-266732"u32 );
	halt if( ust::to_string32( 36893485948395847680.0f ) != "36893486e12"u32 );
	halt if( ust::to_string32( ust::plus_inf </f32/>() ) !=  "inf"u32 );
	halt if( ust::to_string32( ust::minus_inf</f32/>() ) != "-inf"u32 );
	halt if( ust::to_string32( 0.0f / 0.0f ) != "nan"u32 );
}

fn TestAllF32Conversions()
{
	// Test conversions of ALL f32 numbers. We have only 4294967296 such numbers.

	auto mut i= 0u;
	loop
	{
		TestF32Conversion( f32( byte32( i ) ) );

		if( i == 0xFFFFFFFFu )
		{
			break;
		}
		++i;
	}
}

// Test against a parser - a stringified and then parsed number should remain the same.
fn TestF32Conversion( f32 num )
{
	var ust::string8 s= ust::to_string8( num );
	var f32 num_parsed= ParseF32( s );

	if( ust::is_nan( num ) )
	{
		// For "nan" should parse "nan".
		halt if( ! ust::is_nan( num_parsed ) );
	}
	else
	{
		// Compare exact result for non-"nan" values.
		halt if( num_parsed != num );
	}
}

fn TestF64Conversions()
{
	// Test exact string output for each given number.
	// Doing so we ensure that the result is pretty enough.
	// But if the implementation changes, we need to correct these test-cases.
	var [ tup[ f64, ust::string_view8 ], 68 ] special_numbers
	[
		[ f64( byte64( 0xFFF8000000000000u64 ) ), "-nan" ], // Signaling NaN.
		[ f64( byte64( 0xFFF0000000000001u64 ) ), "-nan" ], // Quiet NaN.
		[ -( 0.0 / 0.0 ), "-nan" ], // NaN.
		[ -1.0 / 0.0, "-inf" ], // Negative infinity.
		[ -f64( byte64( 0x7FEFFFFFFFFFFFFFu64 ) ), "-17976931348623158e292" ], // Max finite f64.
		[ -f64( byte64( 0x7FEFFFFFFFFFFFFEu64 ) ), "-17976931348623156e292" ], // Previous before max finite f64.
		[ -f64( 77336774484233477448447755e145 ), "-7733677448423348e155" ],
		[ -f64( 3646344784548473365674724772447772347878233676.0 ), "-36463447845484737e29" ],
		[ -f64( 4546583568534785864.0 ), "-4546583568534786e3" ],
		[ -f64( 137844884348904354.0 ), "-13784488434890435e1" ],
		[ -f64( 44754589900448395.0 ), "-44754589900448395" ],
		[ -f64( 3578434443348952.0 ), "-3578434443348952" ],
		[ -f64( 475344556724754.0 ), "-475344556724754" ],
		[ -f64( 5646744445455.0 ), "-5646744445455" ],
		[ -f64( 267336.2 ), "-267336.2" ],
		[ -f64( 99.99 ), "-99.99" ],
		[ -f64( 34.75 ), "-34.75" ],
		[ -f64( 7.125 ), "-7.125" ],
		[ -f64( 7.0 ), "-7" ],
		[ -f64( byte64( 0x3FF0000000000001u64 ) ), "-1.0000000000000003" ], // Next number after 1.
		[ -1.0, "-1" ],
		[ -f64( byte64( 0x3FEFFFFFFFFFFFFFu64 ) ), "-0.9999999999999999" ], // Previous before 1.
		[ -f64( 0.3 ), "-0.3" ],
		[ -f64( 0.21875 ), "-0.21875" ],
		[ -f64( 0.1 ), "-0.10000000000000001" ],
		[ -f64( 0.046875 ), "-46875e-6" ],
		[ -f64( 0.00390625 ), "-390625e-8" ],
		[ -f64( 3473367784434754344454e-260 ), "-34733677844347547e-255" ],
		[ -f64( byte64( 0x0010000000000001u64 ) ), "-2225073858507202e-323" ], // Next number after min normal.
		[ -f64( byte64( 0x0010000000000000u64 ) ), "-22250738585072016e-324" ], // Min normal.
		[ -f64( byte64( 0x0000480840002042u64 ) ), "-391301328884274e-324" ], // Some subnormal.
		[ -f64( byte64( 0x0000000000000002u64 ) ), "-1e-323" ], // Next number after min subnormal.
		[ -f64( byte64( 0x0000000000000001u64 ) ), "-6e-324" ], // Min subnormal.
		[ -0.0, "-0" ],
		[ 0.0, "0" ],
		[ f64( byte64( 0x0000000000000001u64 ) ), "6e-324" ], // Min subnormal.
		[ f64( byte64( 0x0000000000000002u64 ) ), "1e-323" ], // Next number after min subnormal.
		[ f64( byte64( 0x0000480840002042u64 ) ), "391301328884274e-324" ], // Some subnormal.
		[ f64( byte64( 0x0010000000000000u64 ) ), "22250738585072016e-324" ], // Min normal.
		[ f64( byte64( 0x0010000000000001u64 ) ), "2225073858507202e-323" ], // Next number after min normal.
		[ f64( 3473367784434754344454e-260 ), "34733677844347547e-255" ],
		[ f64( 0.00390625 ), "390625e-8" ],
		[ f64( 0.046875 ), "46875e-6" ],
		[ f64( 0.1 ), "0.10000000000000001" ],
		[ f64( 0.21875 ), "0.21875" ],
		[ f64( 0.3 ), "0.3" ],
		[ f64( byte64( 0x3FEFFFFFFFFFFFFFu64 ) ), "0.9999999999999999" ], // Previous before 1.
		[ 1.0, "1" ],
		[ f64( byte64( 0x3FF0000000000001u64 ) ), "1.0000000000000003" ], // Next number after 1.
		[ f64( 7.0 ), "7" ],
		[ f64( 7.125 ), "7.125" ],
		[ f64( 34.75 ), "34.75" ],
		[ f64( 99.99 ), "99.99" ],
		[ f64( 267336.2 ), "267336.2" ],
		[ f64( 5646744445455.0 ), "5646744445455" ],
		[ f64( 475344556724754.0 ), "475344556724754" ],
		[ f64( 3578434443348952.0 ), "3578434443348952" ],
		[ f64( 44754589900448395.0 ), "44754589900448395" ],
		[ f64( 137844884348904354.0 ), "13784488434890435e1" ],
		[ f64( 4546583568534785864.0 ), "4546583568534786e3" ],
		[ f64( 3646344784548473365674724772447772347878233676.0 ), "36463447845484737e29" ],
		[ f64( 77336774484233477448447755e145 ), "7733677448423348e155" ],
		[ f64( byte64( 0x7FEFFFFFFFFFFFFEu64 ) ), "17976931348623156e292" ], // Previous before max finite f64.
		[ f64( byte64( 0x7FEFFFFFFFFFFFFFu64 ) ), "17976931348623158e292" ], // Max finite f64.
		[ 1.0 / 0.0, "inf" ], // Infinity.
		[ 0.0 / 0.0, "nan" ], // NaN.
		[ f64( byte64( 0x7FF0000000000001u64 ) ), "nan" ], // Quiet NaN.
		[ f64( byte64( 0x7FF8000000000000u64 ) ), "nan" ], // Signaling NaN.
	];

	// Test conversion itself.
	foreach( &pair : special_numbers )
	{
		TestF64Conversion( pair[0] );
	}

	// Test exact string output.
	foreach( &pair : special_numbers )
	{
		var ust::string8 s= ust::to_string8( pair[0] );
		halt if( s != pair[1] );
	}
}

fn TestF64ConversionsForPowersOfTwoAndNearbyNumbers()
{
	var f64 mut power_of_two= 1.0;
	for( auto mut i= 0s; i < 1025s; ++i )
	{
		// Test numbers around given point.
		for( auto mut delta= -64i64; delta <= 64i64; ++delta )
		{
			TestF64Conversion( f64( byte64( i64( byte64( power_of_two ) ) + delta ) ) );
		}

		var f64 inv_power_of_two= 1.0 / power_of_two;

		// Test numbers around given point.
		for( auto mut delta= -64i64; delta <= 64i64; ++delta )
		{
			TestF64Conversion( f64( byte64( i64( byte64( inv_power_of_two ) ) + delta ) ) );
		}

		power_of_two*= 2.0;
	}
}

fn TestF64ConversionsForPowersOfTenAndNearbyNumbers()
{
	var f64 mut power_of_ten= 1.0;
	for( auto mut i= 0s; i < 310s; ++i )
	{
		// Test numbers around given point.
		for( auto mut delta= -100i64; delta <= 100i64; ++delta )
		{
			TestF64Conversion( f64( byte64( i64( byte64( power_of_ten ) ) + delta ) ) );
		}

		var f64 inv_power_of_ten= 1.0 / power_of_ten;

		// Test numbers around given point.
		for( auto mut delta= -100i64; delta <= 100i64; ++delta )
		{
			TestF64Conversion( f64( byte64( i64( byte64( inv_power_of_ten ) ) + delta ) ) );
		}

		power_of_ten*= 10.0;
	}
}

fn TestRandomF64Conversions()
{
	var RandGenerator mut rand;

	// It's far way less than the total number of "f64" numbers, but is still pretty high.
	var u32 num_tested_random_numbers= 1u << 21u;

	for( auto mut i= 0u; i < num_tested_random_numbers; ++i )
	{
		var u64 rand_bit_pattern=
			u64( rand.Next() ) |
			( u64( rand.Next() ) << 16 ) |
			( u64( rand.Next() ) << 32 ) |
			( u64( rand.Next() ) << 48 );

		TestF64Conversion( f64( byte64( rand_bit_pattern ) ) );
	}
}

// Test against a parser - a stringified and then parsed number should remain the same.
fn TestF64Conversion( f64 num )
{
	var ust::string8 s= ust::to_string8( num );
	var f64 num_parsed= ParseF64( s );

	if( ust::is_nan( num ) )
	{
		// For "nan" should parse "nan".
		halt if( ! ust::is_nan( num_parsed ) );
	}
	else
	{
		// Compare exact result for non-"nan" values.
		halt if( num_parsed != num );
	}
}

fn TestF64ConversionsToWideStringTypes()
{
	// Test only some selected values.
	// We don't require testing them all, since underlying implemetation should really not depend on string type.

	halt if( ust::to_string16( 0.0 ) != "0"u16 );
	halt if( ust::to_string16( -0.0 ) != "-0"u16 );
	halt if( ust::to_string16( 0.0009765625 ) != "9765625e-10"u16 );
	halt if( ust::to_string16( 675.125 ) != "675.125"u16 );
	halt if( ust::to_string16( -266732.0 ) != "-266732"u16 );
	halt if( ust::to_string16( 36893485948395847680.0 ) != "36893485948395849e3"u16 );
	halt if( ust::to_string16( ust::plus_inf </f64/>() ) !=  "inf"u16 );
	halt if( ust::to_string16( ust::minus_inf</f64/>() ) != "-inf"u16 );
	halt if( ust::to_string16( 0.0f / 0.0f ) != "nan"u16 );

	halt if( ust::to_string32( 0.0 ) != "0"u32 );
	halt if( ust::to_string32( -0.0 ) != "-0"u32 );
	halt if( ust::to_string32( 0.0009765625 ) != "9765625e-10"u32 );
	halt if( ust::to_string32( 675.125 ) != "675.125"u32 );
	halt if( ust::to_string32( -266732.0 ) != "-266732"u32 );
	halt if( ust::to_string32( 36893485948395847680.0 ) != "36893485948395849e3"u32 );
	halt if( ust::to_string32( ust::plus_inf </f64/>() ) !=  "inf"u32 );
	halt if( ust::to_string32( ust::minus_inf</f64/>() ) != "-inf"u32 );
	halt if( ust::to_string32( 0.0 / 0.0 ) != "nan"u32 );
}

fn TestAllF64Conversions()
{
	// Test conversions of ALL f64 numbers.

	auto mut i= 0u64;
	loop
	{
		TestF64Conversion( f64( byte64( i ) ) );

		if( i == 0xFFFFFFFFFFFFFFFFu64 )
		{
			break;
		}
		++i;
	}
}

class RandGenerator
{
public:
	fn Next( mut this ) : u32
	{
		state_= ( 22695477u * state_ + 1u ) & 0x7FFFFFFFu;
		return state_ >> 16u;
	}

private:
	u32 state_= 0u;
}

fn ParseF32( ust::string_view8 s ) : f32
{
	// Use a number parsing function from the C standard library.
	scoped_array char8 s_nt[ s.size() + 1s ]( s.iter().chain( ust::string_view8( "\0" ).iter() ) );
	var f64 res= unsafe( atof( s_nt.data() ) );
	return f32(res);
}

fn ParseF64( ust::string_view8 s ) : f64
{
	// Use a number parsing function from the C standard library.
	scoped_array char8 s_nt[ s.size() + 1s ]( s.iter().chain( ust::string_view8( "\0" ).iter() ) );
	return unsafe( atof( s_nt.data() ) );
}

// C standard library function.
fn nomangle atof( $(char8) ptr ) unsafe call_conv( "C" ) : f64;
